{
  "name": "yorklog",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "db:migrate": "turbo run db:migrate --filter=@yorklog/backend",
    "db:generate": "turbo run db:generate --filter=@yorklog/backend",
    "db:seed": "turbo run db:seed --filter=@yorklog/backend",
    "db:studio": "turbo run db:studio --filter=@yorklog/backend"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
